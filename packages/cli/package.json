{
  "name": "archlens",
  "version": "0.1.0",
  "description": "ArchLens CLI — Analyze and visualize code architecture",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "archlens": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/archlens/archlens"
  },
  "homepage": "https://github.com/archlens/archlens#readme",
  "bugs": {
    "url": "https://github.com/archlens/archlens/issues"
  },
  "keywords": ["architecture", "code-analysis", "visualization", "static-analysis", "dependency-graph"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@archlens/core": "workspace:*",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
