{
  "name": "archlens-studio",
  "version": "0.2.0",
  "description": "ArchLens — code architecture analysis + distributed system simulator. 8 languages, ConstellationGraph, MCP server.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "archlens-studio": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/muhsinelcicek/archlens"
  },
  "homepage": "https://github.com/muhsinelcicek/archlens#readme",
  "bugs": {
    "url": "https://github.com/muhsinelcicek/archlens/issues"
  },
  "keywords": [
    "architecture",
    "code-analysis",
    "visualization",
    "static-analysis",
    "dependency-graph",
    "simulator",
    "queueing-theory",
    "mcp",
    "developer-tools"
  ],
  "author": "Muhsin Elçiçek",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:types": "tsc --noEmit",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.3",
    "ora": "^8.1.1",
    "tree-sitter": "0.22.4",
    "tree-sitter-c-sharp": "0.23.1",
    "tree-sitter-go": "0.23.4",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-json": "0.24.8",
    "tree-sitter-php": "0.23.12",
    "tree-sitter-python": "0.23.6",
    "tree-sitter-ruby": "0.23.1",
    "tree-sitter-rust": "0.23.3",
    "tree-sitter-swift": "0.7.1",
    "tree-sitter-typescript": "0.23.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@archlens/core": "workspace:*",
    "@archlens/mcp": "workspace:*",
    "@archlens/web": "workspace:*",
    "@types/node": "^25.5.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
