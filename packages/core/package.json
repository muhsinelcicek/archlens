{
  "name": "@archlens/core",
  "version": "0.1.0",
  "description": "Core parsing and architecture analysis engine",
  "publishConfig": { "access": "public" },
  "files": ["dist"],
  "keywords": ["architecture", "code-analysis", "tree-sitter", "parser"],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.3",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-php": "^0.23.8",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.23.2",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
